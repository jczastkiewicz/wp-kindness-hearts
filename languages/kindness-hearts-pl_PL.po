#. Plugin display name; menu and page title
msgid "Kindness Hearts"
msgstr "Serca Życzliwości"

#. Stat card label on admin page
msgid "School-wide points"
msgstr "Punkty w całej szkole"

#. Heading and stat card label
msgid "Classes"
msgstr "Klasy"

#. Placeholder for the new-class input
msgid "e.g. Class 3B"
msgstr "np. Klasa 3B"

#. Button on the admin page
msgid "Add Class"
msgstr "Dodaj klasę"

#. Table header — singular form
msgid "Class"
msgstr "Klasa"

#. Table header
msgid "Points"
msgstr "Punkty"

msgid "Loading…"
msgstr "Ładowanie…"

#. Destructive action button
msgid "Reset all points to zero"
msgstr "Wyzeruj wszystkie punkty"

msgid "Teacher App QR Code"
msgstr "Kod QR aplikacji dla nauczycieli"

msgid "Print this QR code and give it only to teachers."
msgstr "Wydrukuj ten kod QR i przekaż go wyłącznie nauczycielom."

msgid "App URL (scan QR to open teacher app):"
msgstr ""
"Adres aplikacji (zeskanuj QR, aby otworzyć aplikację dla nauczycieli):"

msgid "Print poster for teachers"
msgstr "Drukuj plakat dla nauczycieli"

msgid "Download QR PNG"
msgstr "Pobierz QR jako PNG"

msgid "Regenerate token"
msgstr "Wygeneruj nowy token"

msgid "Open Heart Display"
msgstr "Otwórz ekran z sercem"

#. Custom post type label
msgid "Kindness Class"
msgstr "Klasa życzliwości"

#. REST API error
msgid "No token configured"
msgstr "Brak skonfigurowanego tokena"

#. REST API error
msgid "Invalid token"
msgstr "Nieprawidłowy token"

#. REST API error
msgid "Class name must be between 1 and 100 characters"
msgstr "Nazwa klasy musi mieć od 1 do 100 znaków"

#. REST API error
msgid "A class with that name already exists"
msgstr "Klasa o tej nazwie już istnieje"

#. REST API error
msgid "Class not found"
msgstr "Nie znaleziono klasy"

#. REST API error
msgid "Rate limit exceeded"
msgstr "Przekroczono limit zapytań"

#. REST API error
msgid "Reset already in progress"
msgstr "Zerowanie jest już w toku"

msgid "QR library failed to load — please check your connection."
msgstr ""
"Nie udało się załadować biblioteki QR — sprawdź połączenie z internetem."

msgid "Unable to load teacher QR token."
msgstr "Nie udało się pobrać tokena nauczyciela."

msgid "Request failed"
msgstr "Żądanie nie powiodło się"

msgid "No classes yet. Add one above."
msgstr "Nie ma jeszcze żadnych klas. Dodaj klasę powyżej."

#. Button label in the classes table
msgid "Delete"
msgstr "Usuń"

#. Confirm dialog
msgid "Delete this class and its points?"
msgstr "Czy na pewno usunąć tę klasę i jej punkty?"

#. Confirm dialog
msgid "Reset ALL points to zero? This cannot be undone."
msgstr "Wyzerować WSZYSTKIE punkty? Tej operacji nie można cofnąć."

#. Confirm dialog
msgid "This will invalidate the old QR code. Continue?"
msgstr "Stary kod QR przestanie działać. Kontynuować?"

msgid "Kindness Hearts – Teacher QR Code"
msgstr "Serca Życzliwości – kod QR dla nauczyciela"

msgid "Scan to award kindness points when a pupil helps a classmate"
msgstr ""
"Zeskanuj, aby przyznawać punkty życzliwości, gdy uczeń pomoże koledze lub "
"koleżance"

msgid "How to use"
msgstr "Jak używać"

msgid "Scan the QR code with your phone camera"
msgstr "Zeskanuj kod QR aparatem w telefonie"

msgid "Select your class from the dropdown"
msgstr "Wybierz swoją klasę z listy"

msgid "Tap ❤️ each time a pupil helps a classmate"
msgstr "Stuknij ❤️ za każdym razem, gdy uczeń pomoże koledze lub koleżance"

msgid "Watch the heart on the class screen fill up!"
msgstr "Patrz, jak serce na ekranie w klasie się wypełnia!"

msgid "🔒 For teachers only"
msgstr "🔒 Tylko dla nauczycieli"

msgid "Please do not share this QR code with pupils."
msgstr "Prosimy nie udostępniać tego kodu QR uczniom."

#. Image alt text
msgid "QR Code for teacher app"
msgstr "Kod QR aplikacji dla nauczycieli"
